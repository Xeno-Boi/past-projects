script/source = "extends CanvasLayer

signal start_game

# external nodes
onready var main = get_parent().get_tree()
onready var spawn = get_node(\"/root/Main/Spawn\")
onready var player = get_node(\"/root/Main/stage/Player\")
onready var bed = get_node(\"/root/Main/stage/Bed\")
# internal nodes
onready var HealedLabel = $in_game/HealedTitle/ScoreHealed
onready var DeathIcon = $in_game/DeathIcon
onready var StatHealedLabel = $menu/stat_sheet/HealedTitle/ScoreHealed
onready var in_game = $in_game
onready var menu = $menu
onready var stat_sheet = $menu/stat_sheet
onready var ShiftTime = $in_game/ShiftTimeLabel/shiftTime	# label
onready var ShiftTimer = $in_game/ShiftTimeLabel/shiftTime/ShiftTimer


# counters
var healed = 0
var death = 0
export var shift_time: float = 3	# in minutes
var timer

# variables
var start_position = Vector2(628,396)
var loseSoundPlayed = false
var instructionsOpen = false

func _ready():
	in_game.hide()
	stat_sheet.hide()
	timer = int(floor(shift_time * 60))
	update_time(timer)
	DeathIcon.animation = \"0\"

func _process(delta):
	if (!player.game_started):
		if Input.is_action_just_pressed(\"instruction\"):
			_on_Instructions_pressed()
	HealedLabel.text = str(healed)
	DeathIcon.animation = str(death)
	if death >= 3:
		if !loseSoundPlayed:
			$LoseSound.play()
			game_over(\"Game Over\")
			loseSoundPlayed = true
	elif timer == 0:
		$WinSound.play()
		game_over(\"You Win\")

func healed_increase():
	healed += 1

func dead_increase():
	death += 1

func game_over(message):
	$BGM.stop()
	ShiftTimer.stop()
	show_stat_sheet(message)
	emit_signal(\"game_over\")
	reset_game()

func show_stat_sheet(message):
	StatHealedLabel.text = str(healed)
	in_game.hide()
	show_message(message)
	stat_sheet.show()
	menu.show()
	
func reset_game():
	healed = 0
	death = 0
	timer = int(floor(shift_time * 60))
	main.call_group(\"patients\", \"despawn\")
	spawn.stop()
	player.reset()
	for child in bed.get_children():
		child.patient = null
	
func update_time(time):
	var minute = floor(time/60)
	var second = time % 60
	if second < 10:
		second = \"0\" + str(second)
	else:
		second = str(second)
	ShiftTime.text = str(minute) + \":\" + second

func _on_ShiftTimer_timeout():
	timer -= 1
	update_time(timer)

func StartButton_pressed():
	in_game.show()
	menu.hide()
	ShiftTimer.start()
	update_time(timer)
	emit_signal(\"start_game\")
	player.game_started = true
	player.position = start_position
	$WinSound.stop()
	loseSoundPlayed = false
	$BGM.play()
	instructionsOpen = true
	_on_Instructions_pressed()
	
func show_message(text):
	$menu/MessageLabel.text = text

func _on_ExitArea_healed_patient_entered(body):
	healed_increase()
	main.call_group(\"patients\", \"exit_map\", body)

func _on_ExitArea_patient_exited_screen(body):
	main.call_group(\"patients\", \"despawn_after_leaving\", body)
	
func on_patient_death():
	dead_increase()
	spawn.patientSpawnCount -= 1



func _on_Instructions_pressed():
	# Instructions button is a toggle
	if instructionsOpen:
		# close them and toggle the boolean
		$menu/TutorialBackground.hide()
		$menu/TutorialBackground/TutorialText.hide()
		instructionsOpen = !instructionsOpen
	else:
		# open them and toggle the boolean
		$menu/TutorialBackground.show()
		$menu/TutorialBackground/TutorialText.show()
		instructionsOpen = !instructionsOpen
"


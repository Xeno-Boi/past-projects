; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=4

_global_script_classes=[ {
"base": "KinematicBody2D",
"class": "Mobs",
"language": "GDScript",
"path": "res://Scenes/Enemies/Mobs.gd"
}, {
"base": "Node2D",
"class": "Weapons",
"language": "GDScript",
"path": "res://Scenes/Weapons/Weapons.gd"
} ]
_global_script_class_icons={
"Mobs": "",
"Weapons": ""
}

[application]

config/name="1501-a5"
run/main_scene="res://Scenes/Menus/StartMenu.tscn"
config/icon="res://Assets/icon.png"
config/windows_native_icon="res://Assets/icon.ico"

[autoload]

ScoreSheet="*res://Scenes/score_sheet.gd"

[display]

window/size/width=256
window/size/height=144
window/size/test_width=1280
window/size/test_height=720
window/stretch/mode="2d"
window/stretch/aspect="keep"


drag_left_margin = 0.5
drag_top_margin = 0.5
drag_right_margin = 0.5
drag_bottom_margin = 0.5

[node name="NpcDetector" type="Area2D" parent="."]
collision_layer = 0
collision_mask = 8

[node name="CollisionShape2D" type="CollisionShape2D" parent="NpcDetector"]
shape = SubResource("CircleShape2D_g2els")

[node name="NpcAnxietyTimer" type="Timer" parent="."]

[node name="SiblingAnxietyTimer" type="Timer" parent="."]

[connection signal="area_entered" from="SelectHitBox" to="." method="_on_select_hit_box_area_entered"]
[connection signal="area_exited" from="SelectHitBox" to="." method="_on_select_hit_box_area_exited"]
[connection signal="body_entered" from="NpcDetector" to="." method="_on_npc_detector_body_entered"]
[connection signal="body_exited" from="NpcDetector" to="." method="_on_npc_detector_body_exited"]
[connection signal="timeout" from="NpcAnxietyTimer" to="." method="_on_npc_anxiety_timer_timeout"]
[connection signal="timeout" from="SiblingAnxietyTimer" to="." method="_on_sibling_anxiety_timer_timeout"]
